{
  "rules": {
    "posts": {
      ".read": true,
      "$postId": {
        ".write": "auth != null && ( (!data.exists() && newData.exists()) || (data.exists() && data.child('auteur').val() === auth.token.email) )",
        ".validate": "newData.hasChildren(['auteur','videoUrl','createdAt','mediaType'])",
        "auteur": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "description": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)"
        },
        "videoUrl": {
          ".validate": "newData.isString() && newData.val().matches(/^https?:\\/\\//)"
        },
        "mediaType": {
          ".validate": "newData.isString() && (newData.val() === 'photo' || newData.val() === 'video')"
        },
        "likes": {
          ".write": "auth != null",
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "shares": {
          ".write": "auth != null",
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "likedBy": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.val() === true"
          }
        },
        "comments": {
          "$commentId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['auteur','texte','createdAt']) && newData.child('auteur').isString() && newData.child('texte').isString() && newData.child('createdAt').isNumber()"
          }
        },
        "quiz": {
          ".validate": "!newData.exists() || (newData.hasChildren(['question','options','reponseCorrecte']) && newData.child('question').isString() && newData.child('options').hasChildren(['0','1','2','3']) && newData.child('options/0').isString() && newData.child('options/1').isString() && newData.child('options/2').isString() && newData.child('options/3').isString() && newData.child('reponseCorrecte').isNumber() && newData.child('reponseCorrecte').val() >= 0 && newData.child('reponseCorrecte').val() <= 3)"
        },
        "correctAnswers": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['displayName','email']) && newData.child('displayName').isString() && newData.child('email').isString()"
          }
        }
      }
    }
  }
}
